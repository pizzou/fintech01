# ================================================================
# Growth Finance Services Ltd — Loan Platform
# Single-tenant deployment. Copy this file to .env and fill in real
# values. NEVER commit .env to version control.
# ================================================================

# ---- Database ----
DB_PASSWORD=change_me_strong_password_here

# ---- JWT ----
JWT_SECRET=change_me_to_random_64_char_string_minimum_here_12345678
JWT_EXPIRATION_MS=86400000

# ---- Spring Profile ----
SPRING_PROFILE=default

# ---- CORS (comma-separated) ----
# This bank's public domain(s) only. Normal browser traffic goes through
# nginx same-origin and doesn't need this, but it matters for direct API
# access (Swagger from an office IP, future mobile apps, etc).
CORS_ORIGINS=https://growthfinance.rw,https://www.growthfinance.rw

# ---- Frontend API URL ----
NEXT_PUBLIC_API_URL=/api

# ---- Email (SMTP) ----
# This is the #1 cause of "borrowers never get any email" reports: MAIL_ENABLED defaults to
# false everywhere (application.properties AND docker-compose.yml) so a fresh deploy sends
# nothing until you set this block for real. Gmail: create an App Password at
# https://myaccount.google.com/apppasswords — do NOT use your actual account password, and
# never commit a real value here or anywhere in this repo.
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=REPLACE_WITH_REAL_SENDING_ADDRESS
MAIL_PASSWORD=REPLACE_WITH_REAL_SMTP_APP_PASSWORD
MAIL_FROM=noreply@yourdomain.com

# ---- Production go-live bootstrap (REQUIRED before real customer data) ----
# Leave these blank and the app seeds DEMO data with a published, well-known password
# (admin@growthfinance.rw / Admin@1234) — fine for local dev, never acceptable for a real
# deploy. Set all three below before going live to get one real organization and one real
# admin account instead, with no demo borrowers/loans/payments created at all.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=
BOOTSTRAP_ORG_NAME=
BOOTSTRAP_ORG_COUNTRY=
BOOTSTRAP_ORG_CURRENCY=

# ---- PII field-level encryption (REQUIRED for docker-compose deploy) ----
# Generate each with: openssl rand -base64 32
# APP_ENCRYPTION_KEY encrypts sensitive fields (national ID, phone, address, spouse
# info, bank account) at rest — actual ciphertext in the database, not just access
# control. APP_INDEX_KEY is a SEPARATE key used only to compute lookup hashes (so a
# returning borrower can still be found by phone/national ID without storing them
# in plaintext or a reversible form). Losing either key permanently loses access to
# the data it protects — store them in a secrets manager once you're in production,
# not just this file.
APP_ENCRYPTION_KEY=
APP_INDEX_KEY=

# ---- Flutterwave Payments ----
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
# The "Secret Hash" from Settings > Webhooks in your Flutterwave dashboard —
# verifies incoming webhook calls at /api/public/webhooks/flutterwave are
# genuinely from Flutterwave, not spoofed.
FLUTTERWAVE_WEBHOOK_SECRET=

# ---- Open Exchange Rates (FX) ----
OXR_APP_ID=your_openexchangerates_app_id

# ---- SSL Domain (for Let's Encrypt via deploy/scripts/ssl-init.sh) ----
#   ./deploy/scripts/ssl-init.sh admin@growthfinance.rw growthfinance.rw www.growthfinance.rw
DOMAIN=growthfinance.rw
EMAIL=admin@growthfinance.rw
